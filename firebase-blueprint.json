{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Driver": {
      "title": "Driver",
      "description": "Bus driver details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "assignedBusId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "contact"]
    },
    "Conductor": {
      "title": "Conductor",
      "description": "Bus conductor details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "assignedBusId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "contact"]
    },
    "Bus": {
      "title": "Bus",
      "description": "Bus schedule and details",
      "type": "object",
      "properties": {
        "operator": { "type": "string" },
        "route": { "type": "string" },
        "departureTime": { "type": "string", "format": "date-time" },
        "price": { "type": "number" },
        "totalSeats": { "type": "number" },
        "seatNumbers": { "type": "array", "items": { "type": "string" } },
        "bookedSeats": { "type": "array", "items": { "type": "string" } },
        "driverId": { "type": "string" },
        "conductorId": { "type": "string" }
      },
      "required": ["operator", "route", "departureTime", "price", "totalSeats", "seatNumbers"]
    },
    "Booking": {
      "title": "Booking",
      "description": "User seat booking",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "busId": { "type": "string" },
        "busOperator": { "type": "string" },
        "seatNumbers": { "type": "array", "items": { "type": "string" } },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["PAID", "NOT PAID"] },
        "paymentMethod": { "type": "string" },
        "transactionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "busId", "seatNumbers", "totalPrice", "status", "paymentStatus"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Wallet transaction record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["topup", "payment", "refund", "airtime", "data"] },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "description", "createdAt"]
    },
    "Complaint": {
      "title": "Complaint",
      "description": "User support request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved"] },
        "adminResponse": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "resolvedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "userEmail", "subject", "message", "status", "createdAt"]
    },
    "StaffNotification": {
      "title": "StaffNotification",
      "description": "Notification for staff members",
      "type": "object",
      "properties": {
        "staffId": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["assignment", "alert"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["staffId", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/drivers/{driverId}": {
      "schema": "Driver",
      "description": "Drivers"
    },
    "/conductors/{conductorId}": {
      "schema": "Conductor",
      "description": "Conductors"
    },
    "/buses/{busId}": {
      "schema": "Bus",
      "description": "Bus schedules"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "User bookings"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Wallet transactions"
    },
    "/complaints/{complaintId}": {
      "schema": "Complaint",
      "description": "Support requests"
    },
    "/staff_notifications/{notificationId}": {
      "schema": "StaffNotification",
      "description": "Staff notifications"
    }
  }
}
